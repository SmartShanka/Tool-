    <script>
        // Set current year in footer
        document.getElementById('year').textContent = new Date().getFullYear();
        
        // Mobile menu toggle
        const mobileMenuBtn = document.getElementById('mobile-menu-btn');
        const mainNav = document.getElementById('main-nav');
        
        mobileMenuBtn.addEventListener('click', () => {
            mainNav.classList.toggle('active');
            mobileMenuBtn.innerHTML = mainNav.classList.contains('active') 
                ? '<i class="fas fa-times"></i>' 
                : '<i class="fas fa-bars"></i>';
        });
        
        // DOM elements
        const uploadArea = document.getElementById('upload-area');
        const fileInput = document.getElementById('file-input');
        const qualitySlider = document.getElementById('quality');
        const qualityValue = document.getElementById('quality-value');
        const formatSelect = document.getElementById('format');
        const compressBtn = document.getElementById('compress-btn');
        const resetBtn = document.getElementById('reset-btn');
        const resultsSection = document.getElementById('results');
        const originalImg = document.getElementById('original-img');
        const compressedImg = document.getElementById('compressed-img');
        const originalSize = document.getElementById('original-size');
        const compressedSize = document.getElementById('compressed-size');
        const reductionPercent = document.getElementById('reduction-percent');
        const savings = document.getElementById('savings');
        const newDimensions = document.getElementById('new-dimensions');
        const downloadBtn = document.getElementById('download-btn');
        const spinnerContainer = document.getElementById('spinner-container');
        
        // Variables
        let selectedFile = null;
        let compressedFile = null;
        
        // Event listeners
        uploadArea.addEventListener('click', () => fileInput.click());
        
        uploadArea.addEventListener('dragover', (e) => {
            e.preventDefault();
            uploadArea.classList.add('active');
        });
        
        uploadArea.addEventListener('dragleave', () => {
            uploadArea.classList.remove('active');
        });
        
        uploadArea.addEventListener('drop', (e) => {
            e.preventDefault();
            uploadArea.classList.remove('active');
            
            if (e.dataTransfer.files.length) {
                handleFileSelect(e.dataTransfer.files[0]);
            }
        });
        
        fileInput.addEventListener('change', () => {
            if (fileInput.files.length) {
                handleFileSelect(fileInput.files[0]);
            }
        });
        
        qualitySlider.addEventListener('input', () => {
            qualityValue.textContent = `${qualitySlider.value}%`;
        });
        
        compressBtn.addEventListener('click', compressImage);
        resetBtn.addEventListener('click', resetTool);
        
        // Functions
        function handleFileSelect(file) {
            // Check if file is an image
            if (!file.type.match('image.*')) {
                showError('Please select an image file (JPEG, PNG, or WebP).');
                return;
            }
            
            // Check file size (limit to 10MB)
            if (file.size > 10 * 1024 * 1024) {
                showError('File size exceeds 10MB limit. Please choose a smaller image.');
                return;
            }
            
            selectedFile = file;
            
            // Display original image
            const reader = new FileReader();
            reader.onload = (e) => {
                originalImg.src = e.target.result;
                originalSize.textContent = formatFileSize(file.size);
                
                // Enable buttons
                compressBtn.disabled = false;
                resetBtn.disabled = false;
                
                // Hide previous results
                resultsSection.style.display = 'none';
            };
            reader.readAsDataURL(file);
        }
        
        function compressImage() {
            if (!selectedFile) return;
            
            // Show loading spinner
            spinnerContainer.style.display = 'block';
            compressBtn.disabled = true;
            
            // Simulate compression (in a real app, you would use actual compression libraries)
            setTimeout(() => {
                const quality = parseInt(qualitySlider.value) / 100;
                const format = formatSelect.value === 'auto' ? selectedFile.type.split('/')[1] : formatSelect.value;
                
                // In a real implementation, you would use a library like:
                // - canvas.toBlob() for client-side compression
                // - or send to a server for more advanced compression
                
                // For this demo, we'll simulate compression
                const originalSizeBytes = selectedFile.size;
                const compressedSizeBytes = Math.max(
                    originalSizeBytes * (1 - quality * 0.8), 
                    originalSizeBytes * 0.1
                ); // Simulate size reduction
                
                // Create a mock compressed file
                compressedFile = new Blob([selectedFile], { type: `image/${format}` });
                
                // Display results
                displayResults(originalSizeBytes, compressedSizeBytes, format);
                
                // Hide spinner
                spinnerContainer.style.display = 'none';
                compressBtn.disabled = false;
            }, 1500);
        }
        
        function displayResults(originalSizeBytes, compressedSizeBytes, format) {
            // Set compressed image (same as original for demo)
            compressedImg.src = originalImg.src;
            
            // Update UI
            originalSize.textContent = formatFileSize(originalSizeBytes);
            compressedSize.textContent = formatFileSize(compressedSizeBytes);
            
            const reduction = ((originalSizeBytes - compressedSizeBytes) / originalSizeBytes * 100).toFixed(1);
            reductionPercent.textContent = `${reduction}%`;
            savings.textContent = formatFileSize(originalSizeBytes - compressedSizeBytes);
            
            // Get image dimensions
            originalImg.onload = function() {
                newDimensions.textContent = `${originalImg.naturalWidth} × ${originalImg.naturalHeight}px`;
            };
            
            // Set download link
            downloadBtn.href = URL.createObjectURL(compressedFile);
            downloadBtn.download = `compressed.${format}`;
            
            // Show results with animation
            resultsSection.style.display = 'block';
        }
        
        function resetTool() {
            selectedFile = null;
            compressedFile = null;
            fileInput.value = '';
            originalImg.src = '';
            compressedImg.src = '';
            originalSize.textContent = '-';
            compressedSize.textContent = '-';
            reductionPercent.textContent = '-';
            savings.textContent = '-';
            newDimensions.textContent = '-';
            qualitySlider.value = 80;
            qualityValue.textContent = '80%';
            formatSelect.value = 'auto';
            compressBtn.disabled = true;
            resetBtn.disabled = true;
            resultsSection.style.display = 'none';
            spinnerContainer.style.display = 'none';
        }
        
        function formatFileSize(bytes) {
            if (bytes === 0) return '0 Bytes';
            
            const k = 1024;
            const sizes = ['Bytes', 'KB', 'MB', 'GB'];
            const i = Math.floor(Math.log(bytes) / Math.log(k));
            
            return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];
        }
        
        function showError(message) {
            alert(message);
        }
    </script>
</body>
</html>
